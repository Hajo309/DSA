#include <iostream>
#include <vector>
#include <queue> 

using namespace std;

int smashStones(vector<int>& stones) {
    // hàng đá kiểu PQ, nạp đá vào tự động thành Max-heap
    priority_queue<int> stoneQueue;
    for (int i = 0; i < stones.size(); i++ ) {
        stoneQueue.push(stones[i]);
    }

    // cần ít nhất 2 đá để đối đầu
    while (stoneQueue.size() >= 2) {
        // lấy đá to nhất đưa y,x xong xóa khỏi túi
        int y = stoneQueue.top();
        stoneQueue.pop();

        int x = stoneQueue.top();
        stoneQueue.pop();

        // nếu y lớn hơn thì nạp đá vụn vào, còn ko thì ko làm j hết
        if (y > x) stoneQueue.push(y - x); 
    }

    // nếu túi rỗng trả về 0, nếu còn 1 thì dùng top() để trả về
    if (stoneQueue.empty()) {
        return 0;
    }
    else {
        return stoneQueue.top();
    }
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int n; cin >> n;

    vector<int> stones(n);
    for (int i = 0; i < n; ++i) {
        cin >> stones[i];
    }

    cout << smashStones(stones) << "\n";
    return 0;
}
